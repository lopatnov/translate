{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "Models": {
    "Nllb": {
      "Path": "./models/nllb",
      "EncoderFile": "encoder_model.onnx",
      "DecoderFile": "decoder_model.onnx",
      "TokenizerFile": "sentencepiece.bpe.model",
      "TokenizerConfigFile": "tokenizer.json",
      "MaxTokens": 512,
      "BeamSize": 1
    }
  },
  "LibreTranslate": {
    "BaseUrl": "http://localhost:5000",
    "ApiKey": ""
  }
}
