# Lopatnov.Translate — environment configuration
# Copy this file to docker/.env and adjust values before running docker compose.

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------

# Path to NLLB model directory inside the container (mapped via volume in docker-compose.yml).
# Required if models are not in the default location.
Models__Nllb__Path=/app/models/nllb

# Maximum tokens generated per translation. Default: 512.
# Increase for long documents, decrease to limit latency.
# Models__Nllb__MaxTokens=512

# ---------------------------------------------------------------------------
# LibreTranslate fallback
# ---------------------------------------------------------------------------

# Base URL of a LibreTranslate instance. Leave empty to disable the fallback.
LibreTranslate__BaseUrl=http://libretranslate:5000

# API key for LibreTranslate (leave empty if the instance has no key).
# LibreTranslate__ApiKey=

# ---------------------------------------------------------------------------
# gRPC server
# ---------------------------------------------------------------------------

# Port the gRPC server listens on inside the container.
# The host-side mapping is set in docker-compose.yml (ports:).
# Grpc__Port=5100
